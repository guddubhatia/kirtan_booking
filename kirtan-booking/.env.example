# SSBBN Kirtan Panel — Environment Variables
# Copy this file to .env and fill in your values
# All EXPO_PUBLIC_ variables are accessible in client code

# -------------------------------------------------------
# Firebase Configuration
# Get these from Firebase Console > Project Settings > Your Apps
# -------------------------------------------------------
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:android:abcdef

# -------------------------------------------------------
# Google Sheets Configuration
# -------------------------------------------------------
# The ID of your Google Spreadsheet (from the URL)
EXPO_PUBLIC_SPREADSHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Google Sheets API Key (for read-only client access)
# Create at: https://console.cloud.google.com > APIs & Services > Credentials
EXPO_PUBLIC_GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key

# Service Account for write operations (server-side only — do NOT prefix with EXPO_PUBLIC_)
GOOGLE_SERVICE_ACCOUNT_EMAIL=kirtan-service@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# -------------------------------------------------------
# Backend URL (optional — for write operations via proxy)
# If you deploy a backend, put its URL here
# -------------------------------------------------------
EXPO_PUBLIC_BACKEND_URL=https://your-backend-url.com
