# SSBBN Kirtan Panel — Backend environment
# Copy to `.env` and fill in real values:  cp .env.example .env

# Port the API listens on
PORT=4000

# Secret used to sign JWTs — set a long random string in production.
# Generate one:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# How long admin tokens stay valid
JWT_TTL=30d

# Path to the SQLite file (defaults to server/kirtan.db)
DB_PATH=./kirtan.db

# Initial admin account created by `npm run seed`
ADMIN_EMAIL=admin@ssbbn.local
ADMIN_PASSWORD=changeme123
